# ============================================================
# AI Debate System — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Anthropic Claude API ─────────────────────────────────────
# Required. Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Web Search API ───────────────────────────────────────────
# Required. Supports Tavily (https://tavily.com/) or Brave Search.
SEARCH_API_KEY=your_search_key_here

# Base URL for the search provider's endpoint.
# Tavily:  https://api.tavily.com/search
# Brave:   https://api.search.brave.com/res/v1/web/search
SEARCH_BASE_URL=https://api.tavily.com/search
