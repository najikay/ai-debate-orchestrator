# ============================================================
# AI Debate System — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── LLM Provider — choose ONE of the two blocks below ───────

# Option A: Anthropic Claude (default)
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Option B: Any OpenAI-compatible provider
#   DeepSeek  → LLM_BASE_URL=https://api.deepseek.com
#   Qwen      → LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   OpenAI    → leave LLM_BASE_URL blank (default endpoint used)
#   Ollama    → LLM_BASE_URL=http://localhost:11434/v1
#
# LLM_API_KEY=your_provider_key_here
# LLM_BASE_URL=https://api.deepseek.com

# (Optional) Force a specific provider instead of auto-detection:
# LLM_PROVIDER=anthropic   # or: openai | deepseek | qwen | openai_compatible

# ── Web Search API ───────────────────────────────────────────
# Supports Tavily (https://tavily.com/) or Brave Search.
SEARCH_API_KEY=your_search_key_here

# Base URL for the search provider's endpoint.
# Tavily:  https://api.tavily.com/search
# Brave:   https://api.search.brave.com/res/v1/web/search
SEARCH_BASE_URL=https://api.tavily.com/search
